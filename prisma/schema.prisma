generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum ClipStatus {
  REQUESTED
  PROCESSING
  READY
  FAILED
}

enum ClipTriggerType {
  MANUAL
  CHAT_COMMAND
  KEYWORD
  SPEECH_TO_TEXT
}

enum ClipRulePermission {
  STREAMER_ONLY
  MODERATORS
  SUBSCRIBERS
  EVERYONE
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum SpeechProvider {
  INTERNAL
  WHISPER
  DEEPGRAM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(USER)
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  twitchUserId  String?   @unique
  twitchLogin   String?
  twitchName    String?

  accounts      Account[]
  sessions      Session[]
  clips         Clip[]
  clipTargets   ClipTarget[]
  clipRules     ClipRule[]
  speechEvents  SpeechTranscriptEvent[]
  subscription  Subscription?
  promoRedemptions PromoRedemption[]

  @@index([plan])
  @@index([twitchLogin])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?   @db.Text
  access_token      String?   @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?   @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Clip {
  id             String          @id @default(cuid())
  userId         String
  clipTargetId   String?
  twitchClipId   String?         @unique
  broadcasterId  String
  broadcasterLogin String?
  broadcasterName  String?
  title          String?
  url            String?
  editUrl        String?
  embedUrl       String?
  status         ClipStatus      @default(REQUESTED)
  triggerType    ClipTriggerType @default(MANUAL)
  triggerValue   String?
  errorCode      String?
  errorMessage   String?
  requestedAt    DateTime        @default(now())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clipTarget ClipTarget? @relation(fields: [clipTargetId], references: [id], onDelete: SetNull)
  speechEvents SpeechTranscriptEvent[]

  @@index([userId, createdAt])
  @@index([clipTargetId, createdAt])
  @@index([broadcasterId, createdAt])
  @@index([status])
}

model ClipTarget {
  id           String   @id @default(cuid())
  userId       String
  twitchUserId String
  twitchLogin  String
  twitchName   String?
  externalTriggerToken String? @unique
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clips Clip[]
  speechEvents SpeechTranscriptEvent[]

  @@unique([userId, twitchUserId])
  @@index([userId, isDefault])
  @@index([twitchLogin])
}

model SpeechTranscriptEvent {
  id             String         @id @default(cuid())
  userId         String
  clipTargetId   String?
  clipId         String?
  provider       SpeechProvider
  broadcasterLogin String
  transcript     String         @db.Text
  matchedKeyword String?
  confidence     Float?
  occurredAt     DateTime       @default(now())
  createdAt      DateTime       @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  clipTarget ClipTarget? @relation(fields: [clipTargetId], references: [id], onDelete: SetNull)
  clip       Clip?       @relation(fields: [clipId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([clipTargetId, createdAt])
  @@index([provider, createdAt])
  @@index([matchedKeyword])
}

model ClipRule {
  id                 String             @id @default(cuid())
  userId             String
  enabled            Boolean            @default(true)
  command            String             @default("!clip")
  clipTitleTemplate  String             @default("AutoClip")
  appendCounter      Boolean            @default(true)
  nextClipNumber     Int                @default(1)
  clipDurationSeconds Int               @default(30)
  cooldownSeconds    Int                @default(60)
  lastTriggeredAt    DateTime?
  permission         ClipRulePermission @default(EVERYONE)
  keywords           String[]           @default([])
  speechInstruction  String?            @db.Text
  notifyOnCreate     Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId      String?            @unique
  stripeSubscriptionId  String?            @unique
  stripePriceId         String?
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd      DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  durationHours Int
  maxUses       Int
  usedCount     Int      @default(0)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())

  redemptions PromoRedemption[]

  @@index([expiresAt])
}

model PromoRedemption {
  id           String   @id @default(cuid())
  userId       String
  promoCodeId  String
  redeemedAt   DateTime @default(now())
  accessEndsAt DateTime

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([userId, promoCodeId])
  @@index([userId, accessEndsAt])
  @@index([promoCodeId])
}

model StripeWebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([type])
  @@index([processedAt])
}
